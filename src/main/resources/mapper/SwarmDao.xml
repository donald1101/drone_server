<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hkxx.drone.db.dao.SwarmDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.hkxx.drone.db.entity.SwarmEntity" id="swarmMap">
        <result property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="permission" column="permission"/>
        <result property="swarmtype" column="swarmType"/>
    </resultMap>

    <resultMap type="com.hkxx.drone.db.entity.SwarmDevicePort" id="swarmDevicePortMap">
        <result property="deviceId" column="device_id"/>
        <result property="clientPort" column="value"/>
    </resultMap>

    <select id="selectSwarmDevicePorts" resultMap="swarmDevicePortMap">
        select a.device_id, b.value from swarm_device a left join port b on a.device_id=b.deviceId and
        a.swarm_id=#{swarmId} and b.category=2
    </select>

</mapper>