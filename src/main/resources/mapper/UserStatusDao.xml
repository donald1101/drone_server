<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hkxx.drone.db.dao.UserStatusDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.hkxx.drone.db.entity.UserStatusEntity" id="userStatusMap">
        <result property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="lat" column="lat"/>
        <result property="lng" column="lng"/>
        <result property="taskId" column="task_id"/>
        <result property="instructionId" column="instruction_id"/>
        <result property="updateTime" column="update_time"/>
        <result property="createdTime" column="created_time"/>
    </resultMap>

    <select id="selectByUserId" resultMap="userStatusMap">
        select * from user_status where user_id=#{user_id};
    </select>
</mapper>