<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hkxx.drone.db.dao.CurrentStatusDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.hkxx.drone.db.entity.CurrentStatusEntity" id="currentStatusMap">
        <result property="id" column="id"/>
        <result property="droneId" column="drone_id"/>
        <result property="deviceId" column="device_id"/>
        <result property="alt" column="alt"/>
        <result property="lat" column="lat"/>
        <result property="lng" column="lng"/>
        <result property="horizontalSpeed" column="horizontal_speed"/>
        <result property="verticalSpeed" column="vertical_speed"/>
        <result property="yaw" column="yaw"/>
        <result property="roll" column="roll"/>
        <result property="pitch" column="pitch"/>
        <result property="battery" column="battery"/>
        <result property="gimbalYaw" column="gimbal_yaw"/>
        <result property="gimbalRoll" column="gimbal_roll"/>
        <result property="gimbalPitch" column="gimbal_pitch"/>
        <result property="updateTime" column="update_time"/>
        <result property="hdg" column="hdg"/>
        <result property="state" column="state"/>
    </resultMap>

    <select id="selectByDeviceId" resultMap="currentStatusMap">
        select * from current_status where device_id=#{deviceId};
    </select>
</mapper>