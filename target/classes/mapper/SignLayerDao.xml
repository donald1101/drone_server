<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hkxx.drone.db.dao.SignLayerDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.hkxx.drone.db.entity.SignLayerEntity" id="signLayerMap">
        <result property="id" column="id"/>
        <result property="taskId" column="task_id"/>
        <result property="flightLogId" column="flight_log_id"/>
        <result property="instructionId" column="instruction_id"/>
        <result property="signName" column="sign_name"/>
        <result property="signType" column="sign_type"/>
        <result property="geoType" column="geo_type"/>
        <result property="position" column="position"/>
        <result property="description" column="description"/>
        <result property="recordUserId" column="record_user_id"/>
        <result property="file" column="file"/>
        <result property="state" column="state"/>
        <result property="createdTime" column="created_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectByName" resultMap="signLayerMap">
        select * from sign_layer where sign_name=#{name};
    </select>
</mapper>