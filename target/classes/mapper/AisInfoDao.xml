<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hkxx.drone.db.dao.AisInfoDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.hkxx.drone.db.entity.AisInfoEntity" id="aisInfoMap">
        <result property="id" column="id"/>
        <result property="channel" column="channel"/>
        <result property="mmsiId" column="mmsi_id"/>
        <result property="navigationStatus" column="navigation_status"/>
        <result property="sog" column="sog"/>
        <result property="longitude" column="longitude"/>
        <result property="latitude" column="latitude"/>
        <result property="cog" column="cog"/>
        <result property="course" column="course"/>
        <result property="epfsTime" column="epfs_time"/>
        <result property="imo" column="imo"/>
        <result property="callNum" column="call_num"/>
        <result property="supplierId" column="supplier_id"/>
        <result property="name" column="name"/>
        <result property="type" column="type"/>
        <result property="size" column="size"/>
        <result property="gpsType" column="gps_type"/>
        <result property="eta" column="eta"/>
        <result property="maxStaticDraught" column="max_static_draught"/>
        <result property="destination" column="destination"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <select id="selectByMMSI" resultMap="aisInfoMap">
        select * from ais_info where mmsi_id=#{mmsi};
    </select>
</mapper>