<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hkxx.drone.db.dao.FlightpathDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.hkxx.drone.db.entity.FlightpathEntity" id="flightpathMap">
        <result property="id" column="id"/>
        <result property="executorid" column="executorId"/>
        <result property="executortype" column="executorType"/>
        <result property="planid" column="planId"/>
        <result property="taskid" column="taskId"/>
        <result property="collaboration" column="collaboration"/>
        <result property="height" column="height"/>
        <result property="finishaction" column="finishAction"/>
        <result property="speed" column="speed"/>
        <result property="distance" column="distance"/>
        <result property="content" column="content"/>
    </resultMap>

    <select id="selectByTaskId" resultMap="flightpathMap">
        select * from flightpath where taskid=#{taskId};
    </select>
</mapper>